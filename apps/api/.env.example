# ──────────────────────────────────────────────────
# Arandu API — Variáveis de Ambiente
# ──────────────────────────────────────────────────
# Copie este arquivo para .env e preencha os valores
# cp .env.example .env
# ──────────────────────────────────────────────────

# Ambiente da aplicação
NODE_ENV=development

# ── Banco de Dados ──────────────────────────────
# SQLite local (desenvolvimento)
DATABASE_URL=file:./dev.db
# Turso/LibSQL (produção)
# DATABASE_URL=libsql://<db-name>-<user>.turso.io?authToken=<token>

# ── Autenticação JWT ────────────────────────────
JWT_SECRET=minha-chave-secreta-aqui
REFRESH_SECRET=minha-chave-refresh-aqui

# ── Frontend (CORS + Links de e-mail) ───────────
FRONTEND_URL=http://localhost:5173

# ── SMTP (Nodemailer) ───────────────────────────
# Configuração do servidor SMTP para envio de e-mails
# (confirmação de cadastro, recuperação de senha, exclusão de conta)
# Deixe vazio para simular e-mails no console (modo dev)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Arandu <noreply@arandu.app>"
