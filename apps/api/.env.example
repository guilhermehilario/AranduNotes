# ── Revisa Aula — Backend (NestJS) ──

# Porta do servidor (padrão: 3000)
PORT=3000

# Ambiente: development | production | test
NODE_ENV=development

# URL do banco SQLite (Prisma)
DATABASE_URL=file:./dev.db

# Chave secreta JWT para geração de tokens
# ALTERE para um valor forte em produção!
JWT_SECRET=dev-jwt-secret-change-in-production

# URL(s) do frontend (obrigatório em produção)
# Pode ser uma única URL ou múltiplas separadas por vírgula
# Exemplo: https://meuapp.com
# Exemplo múltiplo: https://meuapp.com,http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Chave secreta para refresh tokens (obrigatório em produção!)
# Gere uma chave forte com: openssl rand -base64 32
REFRESH_SECRET=dev-refresh-secret

# Configuração SMTP para envio de e-mails (verificação, recuperação de senha)
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=your-sendgrid-api-key
# SMTP_FROM=noreply@seudominio.com

# URL base da API (usada nos templates de e-mail)
API_URL=http://localhost:3000
